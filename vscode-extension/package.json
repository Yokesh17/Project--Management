{
  "name": "yokeshr-project-manager",
  "displayName": "Yokesh Project Manager",
  "description": "Manage your Personal Projects directly from VS Code",
  "version": "0.0.2",
  "icon": "media/icon.png",
  "publisher": "yokeshr",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yokesh17/Project--Management"
  },
  "engines": {
    "vscode": ">=1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:personalProjectManager",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "personalProjectManager-explorer",
          "title": "Project Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "personalProjectManager-explorer": [
        {
          "type": "webview",
          "id": "personalProjectManager",
          "name": "Projects",
          "contextualTitle": "Project Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "personalProjectManager.login",
        "title": "Project Manager: Connect with Token"
      },
      {
        "command": "personalProjectManager.logout",
        "title": "Project Manager: Logout"
      },
      {
        "command": "personalProjectManager.refresh",
        "title": "Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "personalProjectManager.createTask",
        "title": "Create Task",
        "icon": "$(add)"
      },
      {
        "command": "personalProjectManager.completeTask",
        "title": "Complete Task",
        "icon": "$(check)"
      },
      {
        "command": "personalProjectManager.openTask",
        "title": "Open Task Details"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "personalProjectManager.refresh",
          "when": "view == personalProjectManager",
          "group": "navigation"
        },
        {
          "command": "personalProjectManager.createTask",
          "when": "view == personalProjectManager",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Personal Project Manager",
      "properties": {
        "personalProjectManager.backendUrl": {
          "type": "string",
          "default": "https://yokesh17.pythonanywhere.com",
          "description": "Base URL for the Project Management API"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "npm run compile && node ./node_modules/mocha/bin/_mocha"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "ts-loader": "^9.5.4",
    "typescript": "^4.9.3",
    "vsce": "^2.15.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "date-fns": "^2.29.3",
    "jwt-decode": "^3.1.2"
  }
}